{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://tannerhill.local/audit-system/evidence-schema.json",
  "title": "Platform Audit Evidence File",
  "description": "Standardized evidence format for the modular audit system v2. Every platform audit skill outputs a JSON file conforming to this schema. This is the contract between platform skills and the audit-synthesizer.",
  "type": "object",
  "required": ["meta", "account_overview", "findings", "diagnosis", "opportunities"],
  "additionalProperties": false,

  "properties": {

    "meta": {
      "type": "object",
      "description": "Audit metadata — who, what, when, how.",
      "required": ["client", "platform", "audit_date", "date_range", "access_level", "depth"],
      "additionalProperties": false,
      "properties": {
        "client": {
          "type": "string",
          "description": "Client display name, e.g. 'Example Client Co.'"
        },
        "platform": {
          "type": "string",
          "description": "Platform identifier. Must match one of the recognized platform keys.",
          "enum": ["google-ads", "meta-ads", "ga4", "klaviyo", "shopify", "bigcommerce", "amazon-ads", "website-cro"]
        },
        "audit_date": {
          "type": "string",
          "format": "date",
          "description": "Date the audit was performed (YYYY-MM-DD)."
        },
        "date_range": {
          "type": "object",
          "description": "Date range of the data analyzed.",
          "required": ["start", "end"],
          "additionalProperties": false,
          "properties": {
            "start": { "type": "string", "format": "date" },
            "end": { "type": "string", "format": "date" }
          }
        },
        "access_level": {
          "type": "string",
          "description": "Level of account access available during audit.",
          "enum": ["full", "read-only", "limited", "screenshot-only"]
        },
        "depth": {
          "type": "string",
          "description": "Audit depth level.",
          "enum": ["deep", "standard", "surface"]
        },
        "auditor_notes": {
          "type": "string",
          "description": "Free-text context about data quality, limitations, or anything the synthesizer should know."
        }
      }
    },

    "account_overview": {
      "type": "array",
      "description": "Top-level account metrics. Every numeric value has both a raw number and a display string. Every data point is labeled with its provenance.",
      "items": { "$ref": "#/$defs/labeled_metric" }
    },

    "campaigns": {
      "type": "array",
      "description": "Campaign-level breakdown. Optional — not all platforms use campaign structures (e.g., Klaviyo uses flows, Shopify uses channels).",
      "items": {
        "type": "object",
        "required": ["name", "type", "status"],
        "properties": {
          "name": { "type": "string", "description": "Campaign name as shown in the platform." },
          "type": { "type": "string", "description": "Campaign type (e.g., 'Performance Max', 'Search', 'Shopping', 'Advantage+', 'Flow', 'Campaign')." },
          "status": { "type": "string", "description": "Campaign status (e.g., 'Eligible', 'Limited by budget', 'Active', 'Paused')." },
          "spend": { "type": "number", "description": "Total spend in the date range." },
          "revenue": { "type": "number", "description": "Total attributed revenue in the date range." },
          "roas": { "type": "number", "description": "Return on ad spend (revenue / spend)." },
          "conversions": { "type": "number", "description": "Total conversions (platform-reported)." },
          "cpa": { "type": "number", "description": "Cost per acquisition (spend / conversions)." },
          "budget_daily": { "type": "number", "description": "Daily budget if applicable." },
          "bid_strategy": { "type": "string", "description": "Bid strategy description." },
          "key_signals": {
            "type": "array",
            "description": "Machine-readable signal tags for the synthesizer (e.g., 'budget_limited', 'above_target_roas', 'creative_fatigue').",
            "items": { "type": "string" }
          }
        }
      }
    },

    "tracking_health": {
      "type": "object",
      "description": "Conversion tracking and measurement health. Optional — primarily for ad platforms and GA4.",
      "properties": {
        "flags": {
          "type": "array",
          "description": "Tracking issues discovered during audit.",
          "items": {
            "type": "object",
            "required": ["title", "severity", "label", "evidence"],
            "properties": {
              "title": { "type": "string", "description": "Short description of the tracking issue." },
              "severity": { "type": "string", "enum": ["critical", "high", "medium", "low"], "description": "Issue severity." },
              "label": { "$ref": "#/$defs/evidence_label" },
              "evidence": { "type": "string", "description": "What was observed that indicates the issue." },
              "source": { "type": "string", "description": "Where in the platform this was observed." },
              "recommendation": { "type": "string", "description": "Suggested fix." }
            }
          }
        },
        "conversion_actions": {
          "type": "array",
          "description": "Inventory of conversion actions / events configured in the platform.",
          "items": {
            "type": "object",
            "required": ["name"],
            "properties": {
              "name": { "type": "string" },
              "source": { "type": "string" },
              "count_type": { "type": "string" },
              "window_days": { "type": "integer" },
              "in_goals": { "type": "boolean", "description": "Whether this action is included in primary conversion goals." },
              "all_conversions": { "type": "number" },
              "all_conv_value": { "type": "number" }
            }
          }
        }
      }
    },

    "findings": {
      "type": "array",
      "description": "Key findings from the audit. Each finding is a discrete observation with supporting evidence.",
      "items": {
        "type": "object",
        "required": ["title", "label", "evidence"],
        "additionalProperties": false,
        "properties": {
          "title": { "type": "string", "description": "One-line summary of the finding." },
          "label": { "$ref": "#/$defs/evidence_label" },
          "evidence": { "type": "string", "description": "Supporting data — numbers, comparisons, observations." },
          "source": { "type": "string", "description": "Where in the platform this was observed. Required when label is OBSERVED." },
          "significance": { "type": "string", "description": "Why this matters — business impact or strategic implication." }
        }
      }
    },

    "anomalies": {
      "type": "array",
      "description": "Unexpected patterns, outliers, or things that don't add up. Optional but valuable for the synthesizer.",
      "items": {
        "type": "object",
        "required": ["description", "label", "evidence"],
        "additionalProperties": false,
        "properties": {
          "description": { "type": "string" },
          "label": { "$ref": "#/$defs/evidence_label" },
          "evidence": { "type": "string" },
          "source": { "type": "string" }
        }
      }
    },

    "diagnosis": {
      "type": "object",
      "description": "Platform-level diagnosis — what's the main constraint and what else is contributing.",
      "required": ["primary_constraint"],
      "additionalProperties": false,
      "properties": {
        "primary_constraint": {
          "type": "object",
          "description": "The single biggest issue or opportunity on this platform.",
          "required": ["title", "description", "evidence_refs"],
          "additionalProperties": false,
          "properties": {
            "title": { "type": "string" },
            "description": { "type": "string" },
            "evidence_refs": {
              "type": "array",
              "items": { "type": "string" },
              "description": "References back to specific data points or findings that support this diagnosis."
            }
          }
        },
        "secondary_constraints": {
          "type": "array",
          "description": "Additional issues ranked by impact.",
          "items": {
            "type": "object",
            "required": ["title", "description", "evidence_refs"],
            "additionalProperties": false,
            "properties": {
              "title": { "type": "string" },
              "description": { "type": "string" },
              "evidence_refs": {
                "type": "array",
                "items": { "type": "string" }
              }
            }
          }
        }
      }
    },

    "opportunities": {
      "type": "array",
      "description": "Prioritized actions. Each opportunity must cite evidence and estimate impact.",
      "items": {
        "type": "object",
        "required": ["action", "priority", "expected_impact", "confidence", "evidence"],
        "additionalProperties": false,
        "properties": {
          "action": { "type": "string", "description": "What to do — specific and actionable." },
          "priority": { "type": "string", "enum": ["CRITICAL", "HIGH", "MEDIUM", "LOW"], "description": "Priority ranking." },
          "expected_impact": { "type": "string", "description": "Estimated impact — revenue, efficiency, or percentage improvement." },
          "confidence": { "type": "string", "enum": ["high", "medium", "low"], "description": "How confident are we in this recommendation." },
          "confidence_reasoning": { "type": "string", "description": "Why we have this confidence level." },
          "evidence": { "type": "string", "description": "Data supporting this opportunity." }
        }
      }
    },

    "cross_channel_signals": {
      "type": "array",
      "description": "Signals this platform audit noticed that require cross-platform investigation. The synthesizer picks these up and checks them against other evidence files.",
      "items": {
        "type": "object",
        "required": ["signal", "check_in", "what_to_look_for"],
        "additionalProperties": false,
        "properties": {
          "signal": { "type": "string", "description": "What was noticed on this platform." },
          "check_in": {
            "type": "array",
            "items": { "type": "string", "enum": ["google-ads", "meta-ads", "ga4", "klaviyo", "shopify", "bigcommerce", "amazon-ads", "website-cro"] },
            "description": "Which other platforms should investigate this signal."
          },
          "what_to_look_for": { "type": "string", "description": "Specific question or data point to check on those platforms." }
        }
      }
    },

    "open_questions": {
      "type": "array",
      "description": "Questions that couldn't be answered with available data. Flagged for the AM or synthesizer.",
      "items": {
        "type": "object",
        "required": ["question"],
        "additionalProperties": false,
        "properties": {
          "question": { "type": "string" },
          "data_needed": { "type": "string", "description": "What data would answer this question." },
          "attempted": { "type": "string", "description": "What was tried and why it didn't work." }
        }
      }
    },

    "raw_metrics": {
      "type": "object",
      "description": "Full data tables the synthesizer may need for deeper analysis. Structure varies by platform — use descriptive keys.",
      "properties": {
        "campaign_details": { "type": "array", "items": { "type": "object" } },
        "conversion_action_details": { "type": "array", "items": { "type": "object" } },
        "auction_insights": { "type": "array", "items": { "type": "object" } },
        "search_term_categories": { "type": "array", "items": { "type": "object" } },
        "flow_details": { "type": "array", "items": { "type": "object" } },
        "product_details": { "type": "array", "items": { "type": "object" } },
        "landing_page_details": { "type": "array", "items": { "type": "object" } },
        "audience_details": { "type": "array", "items": { "type": "object" } },
        "creative_details": { "type": "array", "items": { "type": "object" } },
        "placement_breakdown": { "type": "array", "items": { "type": "object" } },
        "frequency_trend": { "type": "array", "items": { "type": "object" } },
        "customer_cohort_details": { "type": "array", "items": { "type": "object" } },
        "channel_details": { "type": "array", "items": { "type": "object" } },
        "monthly_revenue_details": { "type": "array", "items": { "type": "object" } },
        "discount_details": { "type": "array", "items": { "type": "object" } },
        "source_medium_details": { "type": "array", "items": { "type": "object" } },
        "funnel_details": { "type": "array", "items": { "type": "object" } },
        "device_details": { "type": "array", "items": { "type": "object" } },
        "list_details": { "type": "array", "items": { "type": "object" } },
        "segment_details": { "type": "array", "items": { "type": "object" } },
        "sms_details": { "type": "array", "items": { "type": "object" } },
        "keyword_details": { "type": "array", "items": { "type": "object" } },
        "seller_central_asin_data": { "type": "array", "items": { "type": "object" } },
        "brand_analytics_sqr": { "type": "array", "items": { "type": "object" } },
        "product_line_tacos": { "type": "array", "items": { "type": "object" } },
        "wasted_spend_targets": { "type": "array", "items": { "type": "object" } },
        "customer_details": { "type": "array", "items": { "type": "object" } },
        "funnel_observations": { "type": "array", "items": { "type": "object" } }
      },
      "additionalProperties": {
        "type": "array",
        "items": { "type": "object" },
        "description": "Platform-specific data tables not covered by the named keys above."
      }
    }
  },

  "$defs": {

    "evidence_label": {
      "type": "string",
      "description": "Provenance label for every data point. OBSERVED = pulled directly from platform. CALCULATED = derived from observed values (show formula in source). INFERENCE = logical conclusion from observed data. ASSUMPTION = not verified — state what was assumed. DATA_NOT_AVAILABLE = attempted but couldn't get the data.",
      "enum": ["OBSERVED", "CALCULATED", "INFERENCE", "ASSUMPTION", "DATA_NOT_AVAILABLE"]
    },

    "labeled_metric": {
      "type": "object",
      "description": "A single metric with its value, display format, and provenance label.",
      "required": ["metric", "value", "formatted", "label"],
      "additionalProperties": false,
      "properties": {
        "metric": { "type": "string", "description": "Metric name (e.g., 'Total Spend', 'ROAS', 'AOV')." },
        "value": { "type": "number", "description": "Raw numeric value — the synthesizer does math on this." },
        "formatted": { "type": "string", "description": "Human-readable display string (e.g., '$22,859.21', '5.06x', '2.3%')." },
        "label": { "$ref": "#/$defs/evidence_label" },
        "source": { "type": "string", "description": "Where this number came from. Required for OBSERVED (platform > page > metric). Required for CALCULATED (show formula)." }
      }
    }
  }
}
